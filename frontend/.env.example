# Stellar Network Configuration
# Set to 'testnet' for development or 'mainnet' for production
# Optional: defaults to 'testnet'
VITE_NETWORK=testnet

# Factory Contract ID (REQUIRED)
# The deployed Soroban token-factory contract address on the selected network
# Get this from your contract deployment
VITE_FACTORY_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Pinata IPFS Credentials (REQUIRED for token metadata uploads)
# Get your API key and secret from https://app.pinata.cloud/keys
VITE_IPFS_API_KEY=your_pinata_api_key_here
VITE_IPFS_API_SECRET=your_pinata_api_secret_here
